{
  "name": "CodeBasics Learner Support System",
  "nodes": [
    {
      "parameters": {
        "promptType": "define",
        "text": "=Classify the following learner support query into one of three categories:\n\n1. \"course_access\" - Issues with logging in, course visibility, enrollment problems, or accessing course content\n2. \"refund_request\" - Requests for refunds, money back, or cancellations\n3. \"escalation\" - Billing disputes, legal complaints, threats, abusive language, or queries outside the scope of course access and refunds\n\nLearner ID: {{ $json.learnerId }}\nEmail: {{ $json.email }}\nLearner Query: {{ $json.query }}\n\nReturn your classification with a confidence score (0.0 to 1.0) and brief reasoning.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a query classification specialist for CodeBasics online learning platform. Analyze learner support queries and classify them accurately. Be conservative with confidence scores - if unsure, lower the confidence."
        }
      },
      "id": "4fe42edf-3392-4717-bdb4-84c8d3f01061",
      "name": "Supervisor Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -1120,
        864
      ]
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\"intent\": \"course_access\", \"confidence\": 0.95, \"reasoning\": \"User mentions inability to access a paid course\"}"
      },
      "id": "f67db451-bb24-4f5e-853b-191d76b5ff04",
      "name": "Supervisor Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        -976,
        1088
      ]
    },
    {
      "parameters": {
        "mode": "expression",
        "numberOutputs": 3,
        "output": "={{ $json.output.confidence < 0.80 ? 2 : ($json.output.intent === \"course_access\" ? 0 : ($json.output.intent === \"refund_request\" ? 1 : 2)) }}"
      },
      "id": "2f20ea00-d371-433b-a788-5765e796ae1d",
      "name": "Route by Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
